# ==========================================
# 企业智能办公助手平台 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ==========================================

# === DeepSeek LLM (兼容所有 OpenAI 接口) ===
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=30

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MySQL ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=eao_user
MYSQL_PASSWORD=eao_pass_2026
MYSQL_DATABASE=enterprise_ai_office
MYSQL_ROOT_PASSWORD=eao_root_2026

# === ChromaDB ===
CHROMA_HOST=localhost
CHROMA_PORT=8001

# === 应用 ===
APP_ENV=development
LOG_LEVEL=INFO
MAX_RETRY=3

# === OA/CRM (可选，不配则使用 Mock) ===
OA_API_URL=
CRM_API_URL=

# === SSO/LDAP (可选，默认不启用) ===
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.company.com:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_USER_DN_TEMPLATE=cn={username},ou=users,dc=company,dc=com
OIDC_ENABLED=false
OIDC_ISSUER=https://keycloak.company.com/realms/main
OIDC_CLIENT_ID=eao-platform
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/login
