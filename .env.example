# 知识库 RAG 环境变量示例

# LLM
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=30

# PostgreSQL + pgvector（唯一知识库后端）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=knowledge_rag
PG_USER=rag_user
PG_PASSWORD=change-me

# 可选：认证用户与 refresh token 存储
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=knowledge_rag
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-this-to-a-random-secret

# RAG 性能
RAG_SEARCH_K=20
RAG_RERANK_TOP_N=5
RAG_ONLINE_RERANK=false
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_LOCAL_FILES_ONLY=true
RAG_RERANK_CANDIDATE_K=20
RAG_RERANK_MIN_CANDIDATES=3
RAG_RERANK_BATCH_SIZE=8
RAG_RERANK_TIMEOUT_MS=1200

# 上下文预算：仅将高价值、可引用的证据送入模型
RAG_CONTEXT_MAX_TOKENS=3000
RAG_CONTEXT_MIN_TOKENS_PER_SOURCE=180
RAG_CONTEXT_MAX_TOKENS_PER_SOURCE=900
RAG_CONTEXT_DOCUMENT_CAP=2

# 可信生成：资料不足拒答，引用覆盖不合格最多重生成一次
RAG_TRUST_MIN_EVIDENCE_CHARS=80
# 证据中至少命中的有效问题关键词数；防止无关召回被误当作依据
RAG_TRUST_MIN_QUERY_TERM_HITS=1
RAG_TRUST_MIN_CLAIM_CHARS=12
RAG_TRUST_REGENERATION_ENABLED=true

# 内部过程追踪：仅写入脱敏 JSONL，不扩展 SSE 返回内容
RAG_TRACE_ENABLED=true

# QueryPlan：仅追问或弱信号检索时调用 LLM；普通问题保持单次检索
RAG_QUERY_PLAN_ENABLED=true
RAG_QUERY_PLAN_MIN_TERM_HITS=4
RAG_QUERY_PLAN_VARIANT_LIMIT=2
RAG_QUERY_PLAN_MIN_CANDIDATES=3
RAG_QUERY_PLAN_DOCUMENT_CAP=2
RAG_FEEDBACK_SLA_HOURS=72
RAG_TOTAL_LATENCY_ALERT_P95_MS=3000
RAG_LATENCY_ALERT_MIN_SAMPLES=20

# 应用
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
