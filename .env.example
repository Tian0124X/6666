# 知识库 RAG 环境变量示例

# LLM
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=30

# PostgreSQL + pgvector（唯一知识库后端）
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=knowledge_rag
PG_USER=rag_user
PG_PASSWORD=change-me

# 可选：认证用户与 refresh token 存储
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=rag_user
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=knowledge_rag
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-this-to-a-random-secret

# RAG 性能
RAG_SEARCH_K=20
RAG_RERANK_TOP_N=5
RAG_ONLINE_RERANK=false

# 应用
APP_ENV=development
LOG_LEVEL=INFO
FRONTEND_URL=http://localhost:5173
