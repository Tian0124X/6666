# ==========================================
# 企业智能办公助手平台 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ==========================================

# === HuggingFace 镜像 (国内加速，可选) ===
# HF_ENDPOINT=https://hf-mirror.com

# === DeepSeek LLM (兼容所有 OpenAI 接口) ===
LLM_API_KEY=sk-your-deepseek-key-here
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com
LLM_TIMEOUT=30

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === MySQL ===
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=enterprise_ai_office
MYSQL_ROOT_PASSWORD=root123

# === ChromaDB (备胎，pgvector 失效时自动回退) ===
CHROMA_HOST=localhost
CHROMA_PORT=8000

# === PostgreSQL + pgvector (主力向量库) ===
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=enterprise_ai_office
PG_USER=eao_user
PG_PASSWORD=eao_pass_2026

# === JWT 认证 ===
JWT_SECRET=change-this-to-a-random-secret

# === 前端 (生产 CORS) ===
FRONTEND_URL=http://localhost:5173

# === RAG 调优 ===
RAG_BM25_ENABLED=true
RAG_SEARCH_K=20
RAG_RERANK_TOP_N=5
RAG_KNOWLEDGE_FAST_CHANNEL=true

# === 图谱检索后端 (lightrag | neo4j | none) ===
GRAPH_BACKEND=lightrag
LIGHTRAG_PERSIST_DIR=./data/lightrag

# === Neo4j 知识图谱 (可选，GRAPH_BACKEND=neo4j 时启用) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_ENABLED=false

# === 应用 ===
APP_ENV=development
LOG_LEVEL=INFO
MAX_RETRY=3

# === OA/CRM (可选，不配则使用 Mock) ===
OA_API_URL=
CRM_API_URL=

# === SSO/LDAP (可选，默认不启用) ===
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.company.com:389
LDAP_BASE_DN=dc=company,dc=com
LDAP_USER_DN_TEMPLATE=cn={username},ou=users,dc=company,dc=com
OIDC_ENABLED=false
OIDC_ISSUER=https://keycloak.company.com/realms/main
OIDC_CLIENT_ID=eao-platform
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:5173/login
